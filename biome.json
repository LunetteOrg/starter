{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "files": {
    "includes": ["apps/**", "packages/**", "*.json", "*.js", "*.ts"]
  },
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedImports": "error",
        "noUnusedVariables": "warn"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "asNeeded"
    }
  },
  "overrides": [
    {
      "includes": ["apps/web/app/domain/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "paths": {
                  "react-router": "Framework forbidden in domain. Domain must stay pure.",
                  "~/lib": "Lib forbidden in domain. Use injected interfaces only."
                }
              }
            }
          }
        }
      }
    },
    {
      "includes": ["apps/web/app/routes/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "paths": {
                  "~/use-cases": "Use context.app.useCases instead.",
                  "~/domain": "Use context.app instead.",
                  "~/lib/db": "DB forbidden in routes.",
                  "~/bootstrap": "Use context.app in routes, never import bootstrap directly."
                }
              }
            }
          }
        }
      }
    }
  ]
}
