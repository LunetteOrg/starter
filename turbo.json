{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalPassThroughEnv": ["*"],
  "tasks": {
    "lint": { "outputs": [], "cache": false },
    "lint:fix": { "outputs": [], "cache": false },
    "typecheck": { "outputs": [] },
    "test": {
      "outputs": ["coverage/**"]
    },
    "build": {
      "dependsOn": ["^build", "lint", "typecheck"],
      "inputs": ["$TURBO_DEFAULT$", ".env"],
      "outputs": ["build/**", "dist/**", ".react-router/**"],
      "env": ["NODE_ENV"]
    },
    "start": { "dependsOn": ["build"], "cache": false, "persistent": true },
    "dev": { "cache": false, "persistent": true },
    "db:migrate": { "cache": false, "outputs": [] },
    "db:generate": { "cache": false, "outputs": ["drizzle/**"] },
    "test:e2e": {
      "dependsOn": ["build"],
      "cache": false
    }
  }
}
