# EditorConfig — https://EditorConfig.org
# Baseline for editors without the Biome extension and for file types Biome
# doesn't format (YAML, .env, etc.). Values mirror @starter/biome-config
# (indentStyle: space, indentWidth: 2) so the two never disagree.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Markdown uses two trailing spaces as a hard line break — don't strip them.
[*.md]
trim_trailing_whitespace = false
