// TEMPLATE — copy to `apps/<app>/app/arch.spec.ts` when you create the first
// app, then rename by dropping `.template`. Adapt the `forbidden` patterns to
// the app's real layers.
//
// These tests mirror the Biome `noRestrictedImports` overrides in `biome.json`
// (ADR-0002 — import boundaries): the SAME violation must fail both the lint and this test. When you
// change a boundary, update BOTH.
//
// Why a test on top of the lint? `assertLayerBoundaries` is built on
// `getImports`, so it also catches dynamic `import()` (static and
// template-literal forms) that `noRestrictedImports` (static) misses. And
// `getImports` throws if the glob matches nothing → no "empty pass" if you move
// a folder.

import { resolve } from 'node:path'
import {
  assertLayerBoundaries,
  assertNoEntitySpreadInReturn,
  assertNoSourcePattern,
} from '@starter/test-utils'
import { describe, it } from 'vitest'

const APP = resolve(__dirname)

describe('architecture boundaries', () => {
  // The domain stays pure: no framework, no lib/infrastructure.
  // The one typical exception: the typed-error contract (ADR-0002 — typed errors).
  it('domain imports nothing from framework or lib', async () => {
    await assertLayerBoundaries({
      pattern: resolve(APP, 'domain/**/*.{ts,tsx}'),
      layer: 'domain',
      forbidden: [/^react-router/, /^#app\/lib\/(?!db\/errors['"])/, /^@starter\/db/],
    })
  })

  // Use-cases orchestrate the domain via injected ports: no framework,
  // no concrete DB/adapters, no bootstrap (that would invert the layering).
  it('use-cases import no framework, concrete db, adapters or bootstrap', async () => {
    await assertLayerBoundaries({
      pattern: resolve(APP, 'use-cases/**/*.{ts,tsx}'),
      layer: 'use-cases',
      forbidden: [/^react-router/, /^#app\/lib\/db/, /^#app\/bootstrap/, /^@starter\/db/],
    })
  })

  // Routes consume only `context.app`: never use-cases/domain/db/bootstrap directly.
  it('routes reach the app only through context', async () => {
    await assertLayerBoundaries({
      pattern: resolve(APP, 'routes/**/*.{ts,tsx}'),
      layer: 'routes',
      forbidden: [/^#app\/use-cases/, /^#app\/domain/, /^#app\/lib\/db/, /^#app\/bootstrap/],
    })
  })

  // Routes must not over-serialize: a loader/action's return is shipped whole to
  // the browser (turbo-stream), so `return { ...entity }` leaks every column.
  // Return an explicit read-view/DTO literal instead (ADR-0002 — loader/action
  // serialization boundary). The per-route golden test (me.test.ts) pins the
  // exact key set; this catches the spread footgun across all routes at once.
  it('loaders/actions never spread an entity into the returned payload', async () => {
    await assertNoEntitySpreadInReturn({
      pattern: resolve(APP, 'routes/**/*.{ts,tsx}'),
      layer: 'routes',
    })
  })
})

// Code rules (not import boundaries) — each mirrors a Biome net in `biome.json`
// (ADR-0002): the SAME violation must fail both lint and this test. Keep them in
// sync. `assertNoSourcePattern` throws on an empty glob, so a moved layer fails
// loudly instead of passing vacuously.
describe('app code rules', () => {
  // Errors are values (`errore` typed errors), not exceptions — `throw` is only
  // for framework signals (`throw redirect(...)`) (ADR-0002 — typed errors).
  it('never `throw new Error()` anywhere in app code', async () => {
    await assertNoSourcePattern({
      pattern: resolve(APP, '**/*.{ts,tsx}'),
      layer: 'app',
      forbidden: [
        {
          regex: /\bthrow\s+new\s+\w*Error\b/,
          message: 'Return an errore typed error instead of throwing (ADR-0002 — typed errors).',
        },
      ],
    })
  })

  // `process.env` is read in exactly one place: config/env.ts (ADR-0002).
  it('reads process.env only in config/env.ts', async () => {
    await assertNoSourcePattern({
      pattern: resolve(APP, '**/*.{ts,tsx}'),
      layer: 'app',
      forbidden: [
        {
          regex: /\bprocess\s*\.\s*env\b/,
          message: 'Read env only in config/env.ts (ADR-0002 — layered architecture).',
        },
      ],
      ignore: ['**/config/env.ts'],
    })
  })
})
